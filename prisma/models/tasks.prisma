model tasks {
  id          Int      @id @default(autoincrement())
  userid      Int
  supplierid      Int 
  address     String
  description String
  city    String
  url         String?
  status      Status   @default(PENDING)
  date        DateTime? 
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  supplier    suppliers    @relation(fields: [supplierid], references: [id], onDelete: Cascade)
}